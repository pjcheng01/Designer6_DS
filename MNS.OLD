//
//      AutoCAD 功能表檔 - C:\DESIGNER\Designer.mnc
//

***MENUGROUP=DESIGNER

***POP11
               [機械設計家]
               [自定圖庫管理]^C^C^P(loaddesigner) userblk1 
               [使用自定圖庫]^C^C^P(loaddesigner) userblk2 
               [->符號庫]
                 [管理油氣壓符號]^C^C^P(loaddesigner) oilgas1 
                 [<-使用油氣壓符號]^C^C^P(loaddesigner) oilgas2 
               [--]
               [CNS 加工符號]^C^C^P(loaddesigner) (cond ((null c:cns_finish)(load "auxdim"))(t (princ))) cns_finish 
               [JIS 加工符號]^C^C^P(loaddesigner) (cond ((null c:jis_finish)(load "auxdim"))(t (princ))) jis_finish 
               [--]
               [放圖框定比例]^C^C^P(loaddesigner) (cond ((null c:SHSCAL)(load "SHSCAL"))(t (princ))) (if (= shscal-type t) (c:autoSHSCAL) (c:shscal))
               [重設比例]^C^C^P(loaddesigner) (cond ((null c:resetting)(load "SHSCAL"))(t (princ)))^P resetting
               [比例查詢]^C^C^P(loaddesigner) (cond ((null c:scal)(load "aux-qury"))(t (princ)))^P SCAL 
               [修改圖框屬性]^C^C^P(loaddesigner) (cond ((null c:chsheet_att)(load "SHSCAL"))(t (princ)))^P chsheet_att
               [--]
               [使用辭庫]^C^C^P(loaddesigner) (cond ((null c:useword)(load "wordlib1"))(t (princ))) useword 
               [建立辭庫]^C^C^P(loaddesigner) (cond ((null c:creatword)(load "wordlib1"))(t (princ))) creatword 
               [載入文字檔]^C^C^P(loaddesigner) (cond ((null c:asctext)(load "asctext"))(t (princ))) asctext 
               [--]
               [計算機]callcalc 
               [--]
               [->設定目前線性]
                 [粗連續線(SL)]^C^C^P(loaddesigner) SL 
                 [細連續線(TL)]^C^C^P(loaddesigner) TL 
                 [長中心線(CL)]^C^C^P(loaddesigner) CL 
                 [短中心線(SCL)]^C^C^P(loaddesigner) SCL 
                 [虛線(DL)]^C^C^P(loaddesigner) DL 
                 [假想線(PL)]^C^C^P(loaddesigner) PL 
                 [剖面線(HL)]^C^C^P(loaddesigner) HL 
                 [<-尺寸線(D)]^C^C^P(loaddesigner) D 
               [->改變線性]
                 [粗連續線]^C^C^P(loaddesigner) (cond ((null c:chtobyl)(load "auxedit"))(t (princ))) chtosl 
                 [細連續線]^C^C^P(loaddesigner) (cond ((null c:chtobyl)(load "auxedit"))(t (princ))) chtotl 
                 [長中心線]^C^C^P(loaddesigner) (cond ((null c:chtobyl)(load "auxedit"))(t (princ))) chtocl 
                 [短中心線]^C^C^P(loaddesigner) (cond ((null c:chtobyl)(load "auxedit"))(t (princ))) chtocl2 
                 [虛線]^C^C^P(loaddesigner) (cond ((null c:chtobyl)(load "auxedit"))(t (princ))) chtodl 
                 [假想線]]^C^C^P(loaddesigner) (cond ((null c:chtobyl)(load "auxedit"))(t (princ))) chtopl 
                 [剖面線]^C^C^P(loaddesigner) (cond ((null c:chtobyl)(load "auxedit"))(t (princ))) chtohl 
                 [<-尺寸線]^C^C^P(loaddesigner) (chltype "continuous" "3") 
               [--]
               [->系統設定]
                 [材料清單欄寬定義]^C^C^P(loaddesigner) (cond ((null c:defbomlist)(load "dfsystem"))(t (princ)))^p defbomlist
                 [設定線型系統變數]^C^C^P(loaddesigner) (cond ((null c:defltype)(load "dfsystem"))(t (princ)))^p defltype
                 [<-設定圖層系統變數]^C^C^P(loaddesigner) (cond ((null c:deflayer)(load "dfsystem"))(t (princ)))^p deflayer

***POP12
               [客戶化功能]
               [管理自建功能]^C^C^P(loaddesigner) manauser_menu 
               [製作功能幻燈片]^C^C^P(loaddesigner) (cond ((null c:usermake_part_sld)(load "userMENU"))(t (princ))) usermake_part_sld 
               [--]
               [輔助繪圖 DRAW(1)]^C^C^P(loaddesigner) 00 
               [輔助繪圖 DRAW(2)]^C^C^P(loaddesigner) 11 
               [輔助編輯 EDIT(1)]^C^C^P(loaddesigner) 22 
               [輔助編輯 EDIT(2)]^C^C^P(loaddesigner) 33 
               [投影線]^C^C^P(loaddesigner) 44 
               [作圖線性設定]^C^C^P(loaddesigner) 55 
               [--]
               [輔助標註]^C^C^P(loaddesigner) 77 
               [幾何公差標註]^C^C^P(loaddesigner) 88 
               [--]
               [組合圖與材料清單]^C^C^P(loaddesigner) 110 
               [圖層控制]^C^C^P(loaddesigner) 111 
               [--]
               [資料查詢]^C^C^P(loaddesigner) 113 
               [--]
               [機械圖(鍵槽與螺紋孔)]^C^C^P(loaddesigner) 115 
               [機械圖(軸)]^C^C^P(loaddesigner) 116 


