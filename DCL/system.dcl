defball:dialog{label="指標球定義";
               :row{
                    :column{
                             :boxed_column{
                                           label="指標球狀態";
                                           :radio_button{
                                                         label="有";
                                                         key="ball";
                                                        }//end of radio_button
                                           :radio_button{
                                                         label="無";
                                                         key="noball";
                                                        }//end of radio_button
                                          }//end of boxed_column
                             :boxed_column{
                                           label="指標型式";
                                       //  :radio_button{
                                       //              label="無";
                                       //                key="none";
                                       //               }//end of radio_button
                                           :radio_button{
                                                         label="圓點";
                                                         key="donut";
                                                        }//end of radio_button
                                           :radio_button{
                                                         label="箭頭";
                                                         key="arror";
                                                        }//end of radio_button
                                           }//end of boxed_column
                           }//end of column

                    :column{
                           :image{
                                  key="balltype";
                                  width=5;
                                  height=8;
                                  color=-2;
                                 }//end of image
                           :boxed_column{
                                         label="1:1 出圖尺寸";
                                         :edit_box{
                                                   label="字高:";
                                                   key="txth";
                                                   edit_width=6;}
                                         :edit_box{
                                                   label="指標球直徑:";
                                                   key="balldia";
                                                   edit_width=6;}
                                         :edit_box{
                                                   label="指線尺寸:";
                                                   key="pointsize";
                                                   edit_width=6;}
                                        }//end of boxed_column
                           }//end of column
                   }//end of row
                ok_cancel;
                errtile;

}



