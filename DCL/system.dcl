defbom:dialog{
               label="材料清單欄位順序定義";
                            spacer_1;
          :row{
           :boxed_row{
                         label="件號欄位(材料清單第一欄位)";
                 :column{
                    :text{
                         label="  欄位名稱";
                         }//end of text
                    :edit_box{
                              key="pbom";
                              fixed_width_font=true;
                              edit_width=10;
                             }//end of list_box
                        }//end of column
                    :spacer{width=5;}
                 :column{
                    :text{
                         label="  對應 PDM 欄位";
                         }//end of text
                    :popup_list{
                              key="ppdm";
                              fixed_width_font=true;
                              edit_width=12;
                             }//end of list_box
                        }//end of column
                    :spacer{width=2;}
                 :column{
                    :text{
                         label="欄寬(整數)";
                         }//end of text
                    :edit_box{
                              key="pwid";
                              fixed_width_font=true;
                              edit_width=10;
                             }//end of list_box
                        }//end of column

               }//end of row
              }
               :row{
                    :list_box{
                              label="材料清單欄位";
                              key="bom";
                              fixed_width_font=true;
                              height=5;
                              width=13;
                             }//end of list_box
                    :list_box{
                              label="對應 PDM 欄位";
                              key="pdm";
                              fixed_width_font=true;
                              height=5;
                              width=13;
                             }//end of list_box
                    :list_box{
                              label="欄寬";
                              key="wid";
                              fixed_width_font=true;
                              height=5;
                              width=10;
                             }//end of list_box
                    :column{
                            spacer_1;
