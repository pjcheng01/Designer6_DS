                                      key="add";}
                            :button{label="編輯";
                                      key="edit";}
                            :button{label="刪除";
                                      key="del";}
                            :button{label="上移 ^";
                                      key="up";}
                            :button{label="下移 v";
                                      key="down";}
                            spacer_1;
                           }//end of column
                    }//row
                            spacer_1;
           ok_cancel;
           errtile;
}//end of dialog


